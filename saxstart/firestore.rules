rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: request is from the user owning the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // users/{uid} — only the owner can read/write their profile
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Progress summary
      match /progress/{docId} {
        allow read, write: if isOwner(userId);
      }

      // Practice sessions
      match /sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }

      // Drill scores
      match /drill_scores/{drillId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
